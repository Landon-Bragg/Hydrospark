# HydroSpark Environment Configuration
# Copy this file to .env: cp .env.example .env

# JWT Secret Key (auto-generated on first run if left as-is)
JWT_SECRET_KEY=hydrospark-change-this-in-production

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=hydrospark
DATABASE_URL=mysql+pymysql://root:password@mysql:3306/hydrospark


# Groq API Key — required for HydroBot AI chatbot (free at https://console.groq.com)
GROQ_API_KEY=

# Application Settings
FLASK_ENV=development
FLASK_APP=app.py
REACT_APP_API_URL=http://localhost:5001/api

# ML Model Settings
ANOMALY_THRESHOLD_PERCENTAGE=100
FORECAST_MONTHS=12

# Billing Settings
DEFAULT_RATE_PER_CCF=5.72
